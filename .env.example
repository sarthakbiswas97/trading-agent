# Database (using non-default ports to avoid conflicts)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/vapm
REDIS_URL=redis://localhost:6380

# Blockchain
RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key

# Market Data
BINANCE_API_KEY=optional_for_higher_rate_limits
BINANCE_SECRET_KEY=optional

# Agent Config
AGENT_NAME=VAPM-Alpha
MAX_POSITION_SIZE=0.05
MAX_DAILY_LOSS=0.03
MAX_DRAWDOWN=0.10
TRADE_INTERVAL_SECONDS=60

# ML Model
MODEL_PATH=ml/models/xgb_v1.joblib
PREDICTION_THRESHOLD=0.65
CONFIDENCE_THRESHOLD=0.55

# API (using 8001 to avoid conflict with other projects)
API_HOST=0.0.0.0
API_PORT=8001
